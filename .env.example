# ── arxiv ────────────────────────────────────────────────────────────────────
# Comma-separated list of arxiv category codes
# Full list: https://arxiv.org/category_taxonomy
ARXIV_CATEGORIES=cond-mat.mes-hall,cond-mat.quant-gas,physics.optics

# Comma-separated keywords to filter titles/abstracts (plain text, not regex)
KEYWORDS=topological,polariton,photonic,Bose-Einstein

# Maximum papers to fetch per run (arxiv API hard limit: 2000)
MAX_RESULTS=200

# Maximum papers to include in a single email; extras are noted in the footer
EMAIL_MAX_PAPERS=50

# ── email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_gmail@gmail.com
# Comma-separated recipient addresses
EMAIL_TO=you@example.com

# ── webhook (optional) ────────────────────────────────────────────────────────
# Leave blank to disable. Receives a JSON POST with new papers.
# Example: Slack incoming webhook, n8n, or your own endpoint.
WEBHOOK_URL=

# ── storage ───────────────────────────────────────────────────────────────────
DB_PATH=arxiv_digest.db
# Papers older than this many days are deleted on each run
RETENTION_DAYS=7
